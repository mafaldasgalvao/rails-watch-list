<div class="container">
  <h1><%= @list.name %></h1>

  <div class="actions">
    <%= link_to "Add a Movie", new_list_bookmark_path(@list), class: "btn-primary" %>
    <%= link_to "Delete List", list_path(@list), data: { turbo_method: :delete, turbo_confirm: "Are you sure? This will delete all bookmarks in this list." }, class: "btn-danger" %>
  </div>

  <div class="movies-grid">
    <% if @bookmarks.empty? %>
      <p>No movies added to this list yet.</p>
    <% else %>
      <% @bookmarks.each do |bookmark| %>
        <div class="movie-card">
          <img src="<%= bookmark.movie.poster_url %>" alt="<%= bookmark.movie.title %> poster" />
          <div class="movie-info">
            <h3><%= bookmark.movie.title %> <span class="rating">⭐ <%= bookmark.movie.rating %></span></h3>
            <p class="overview"><%= bookmark.movie.overview %></p>
            <p class="comment"><strong>Note:</strong> "<%= bookmark.comment %>"</p>

            <%= link_to "Remove Movie", bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Remove this movie from the list?" }, class: "btn-delete-link" %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= link_to "Back to Lists", lists_path %>
</div>
